[global_config]
  enabled_plugins = LaunchpadCodeURLHandler, APTURLHandler, LaunchpadBugURLHandler
  ask_before_closing = never
[keybindings]
  split_horiz = <Primary><Shift>o
  split_vert = <Primary><Shift>e
  page_down = <Shift>Page_Down
  page_down_half = <Shift>Page_Up
  toggle_zoom = <Primary><Shift>x
[profiles]
  [[default]]
    font = Monospace 10
    foreground_color = "#ffffff"
    scrollback_infinite = True
    use_system_font = False
    copy_on_selection = True
[layouts]
  [[default]]
    [[[child0]]]
      maximised = True
      order = 0
      parent = ""
      type = Window
    [[[child1]]]
      order = 0
      parent = child0
      position = 500
      type = HPaned
    [[[child2]]]
      order = 0
      parent = child1
      position = 500
      type = VPaned
    [[[child3]]]
      order = 1
      parent = child1
      position = 500
      type = VPaned
    [[[terminal4]]]
      order = 0
      parent = child2
      profile = default
      type = Terminal
    [[[terminal5]]]
      order = 1
      parent = child2
      profile = default
      type = Terminal
    [[[terminal6]]]
      order = 0
      parent = child3
      profile = default
      type = Terminal
    [[[terminal7]]]
      order = 1
      parent = child3
      profile = default
      type = Terminal
[plugins]
